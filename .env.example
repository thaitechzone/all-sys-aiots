# ═══ IoT Stack — คัดลอกเป็น .env แล้วแก้ค่าด้านล่าง ═══
# 📖 รายละเอียด: README.md · SETUP_CREDENTIALS.md

TZ=Asia/Bangkok

# ── Node-RED ──────────────────────────────────────────────
NODERED_USERNAME=admin
# สร้าง hash:  npx bcryptjs "your-password" 8
# 🚨 วางใน .env ต้อง escape $ → $$ ทุกตัว (ไม่งั้น login ไม่ได้)
#    $2b$08$e9VV...  →  $$2b$$08$$e9VV...
NODERED_PASSWORD_HASH=$$2a$$08$$UL6Zwie/yZHpRf4ugI0fq.ktr8VgiYl4OtAQidorGQ7Y6n5nLIFVO

# ── Cloudflare Tunnel (Optional, production) ──────────────
# one.dash.cloudflare.com → Tunnels → Create → copy token (ดู README Step 7)
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token-here

# ── N8N ───────────────────────────────────────────────────
N8N_DOMAIN=n8n.yourdomain.com
# key (hex 32):  node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
N8N_ENCRYPTION_KEY=change-this-to-random-32-char-hex

# ── InfluxDB ──────────────────────────────────────────────
# ORG/BUCKET = ชื่อที่ตั้งเอง · TOKEN (hex 64) ต้องสุ่ม:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ค่าเหล่านี้ init อัตโนมัติ (เฉพาะตอน volume ว่าง — ดู README Step 5)
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=change-this-strong-password
INFLUXDB_ORG=iot_org
INFLUXDB_BUCKET=iot_bucket
INFLUXDB_ADMIN_TOKEN=change-this-to-random-64-char-hex

# ── Grafana ───────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-this-strong-password
